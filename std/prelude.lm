struct SABChannelU32 { sender: SABSenderU32, receiver: SABReceiverU32 }
struct SABChannelF32 { sender: SABSenderF32, receiver: SABReceiverF32 }
struct SABChannelF64 { sender: SABSenderF64, receiver: SABReceiverF64 }

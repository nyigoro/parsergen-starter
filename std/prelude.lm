extern type Renderer from "@std/render";
extern type RenderRoot from "@std/render";
extern type ReactiveRenderRoot from "@std/render";
type Query<T> = { items: Vec<T> };
struct FileMetadata { isFile: bool, isDirectory: bool, size: int, modifiedMs: int }
type Map<K, V> = { size: int };
enum Option<T> { Some(T), None }
enum Result<T, E> { Ok(T), Err(E) }
extern fn map_vec<A, B>(values: Vec<A>, mapper: fn(A) -> B) -> Vec<B> from "@std/iter";
extern fn filter_vec<A>(values: Vec<A>, pred: fn(A) -> bool) -> Vec<A> from "@std/iter";
extern fn filter_option<A>(value: Option<A>, pred: fn(A) -> bool) -> Option<A> from "@std/iter";
extern fn zip_vec<A, B>(left: Vec<A>, right: Vec<B>) -> Vec<Tuple<A, B>> from "@std/iter";
extern fn enumerate_vec<A>(values: Vec<A>) -> Vec<Tuple<int, A>> from "@std/iter";
extern fn flatten_vec<A>(values: Vec<Vec<A>>) -> Vec<A> from "@std/iter";
extern fn flat_map_vec<A, B>(values: Vec<A>, mapper: fn(A) -> Vec<B>) -> Vec<B> from "@std/iter";
extern fn chunk_vec<A>(values: Vec<A>, size: int) -> Vec<Vec<A>> from "@std/iter";
extern fn window_vec<A>(values: Vec<A>, size: int) -> Vec<Vec<A>> from "@std/iter";
extern fn partition_vec<A>(values: Vec<A>, pred: fn(A) -> bool) -> Tuple<Vec<A>, Vec<A>> from "@std/iter";
extern fn take_vec<A>(values: Vec<A>, n: int) -> Vec<A> from "@std/iter";
extern fn skip_vec<A>(values: Vec<A>, n: int) -> Vec<A> from "@std/iter";
extern fn any_vec<A>(values: Vec<A>, pred: fn(A) -> bool) -> bool from "@std/iter";
extern fn all_vec<A>(values: Vec<A>, pred: fn(A) -> bool) -> bool from "@std/iter";
extern fn find_vec<A>(values: Vec<A>, pred: fn(A) -> bool) -> Option<A> from "@std/iter";
extern fn count_vec<A>(values: Vec<A>) -> int from "@std/iter";
extern fn sum_vec(values: Vec<int>) -> int from "@std/iter";
extern fn sum_vec_f64(values: Vec<f64>) -> f64 from "@std/iter";
extern fn unique_vec<A>(values: Vec<A>) -> Vec<A> from "@std/iter";
extern fn reverse_vec<A>(values: Vec<A>) -> Vec<A> from "@std/iter";
extern fn sort_vec<A>(values: Vec<A>, cmp: fn(A, A) -> int) -> Vec<A> from "@std/iter";
extern fn sort_by_vec<A, K>(values: Vec<A>, key: fn(A) -> K) -> Vec<A> from "@std/iter";
extern fn sort_by_desc_vec<A, K>(values: Vec<A>, key: fn(A) -> K) -> Vec<A> from "@std/iter";
extern fn group_by_vec<A, K>(values: Vec<A>, key: fn(A) -> K) -> HashMap<K, Vec<A>> from "@std/iter";
extern fn intersperse_vec<A>(values: Vec<A>, sep: A) -> Vec<A> from "@std/iter";
extern fn join_vec<A, B, K>(left: Vec<A>, right: Vec<B>, left_key: fn(A) -> K, right_key: fn(B) -> K) -> Vec<Tuple<A, B>> from "@std/iter";
extern fn query<T>(items: Vec<T>) -> Query<T> from "@std/query";
extern fn where_q<T>(q: Query<T>, pred: fn(T) -> bool) -> Query<T> from "@std/query";
extern fn select_q<T, U>(q: Query<T>, mapper: fn(T) -> U) -> Query<U> from "@std/query";
extern fn order_by_q<T, K>(q: Query<T>, key: fn(T) -> K) -> Query<T> from "@std/query";
extern fn order_by_desc_q<T, K>(q: Query<T>, key: fn(T) -> K) -> Query<T> from "@std/query";
extern fn limit_q<T>(q: Query<T>, n: int) -> Query<T> from "@std/query";
extern fn offset_q<T>(q: Query<T>, n: int) -> Query<T> from "@std/query";
extern fn group_by_q<T, K>(q: Query<T>, key: fn(T) -> K) -> HashMap<K, Vec<T>> from "@std/query";
extern fn count_q<T>(q: Query<T>) -> int from "@std/query";
extern fn first_q<T>(q: Query<T>) -> Option<T> from "@std/query";
extern fn to_vec_q<T>(q: Query<T>) -> Vec<T> from "@std/query";
extern fn join_q<T, U, K>(left: Query<T>, right: Query<U>, left_key: fn(T) -> K, right_key: fn(U) -> K) -> Query<Tuple<T, U>> from "@std/query";

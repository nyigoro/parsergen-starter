{
  "name": "lumina-lang",
  "version": "0.5.1",
  "type": "module",
  "description": "A modern functional language with async/await, type inference, and package management",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/bin/*.js",
    "dist/bin/*.cjs",
    "dist/index.js",
    "dist/index.cjs",
    "dist/index.d.ts",
    "dist/lumina-runtime.js",
    "dist/lumina-runtime.cjs",
    "std/",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "lumina": "dist/bin/lumina.js",
    "lumina-lsp": "dist/bin/lumina-lsp.js"
  },
  "scripts": {
    "repl": "tsx src/repl.ts",
    "dev": "tsx src/index.ts",
    "build": "npm run build:esm && npm run build:cjs && npm run build:dts && npm run build:clean",
    "build:esm": "tsup src/index.ts src/lumina-runtime.ts src/bin/cli.ts src/bin/lumina.ts src/bin/lumina-lsp.ts src/bin/lumina-worker.ts --format esm --clean",
    "build:cjs": "tsup src/index.ts src/lumina-runtime.ts src/bin/cli-cjs.ts src/bin/lumina-cjs.ts src/bin/lumina-lsp.ts src/bin/lumina-worker.ts --format cjs --clean false && node scripts/rename-cjs.cjs",
    "build:dts": "tsup src/index.ts --format esm --dts --clean false",
    "build:clean": "node scripts/clean-dist-bin.mjs",
    "build:verify": "node scripts/verify-dist.cjs",
    "verify": "npm run lint:check && npm run build && npm test",
    "test": "jest --config jest.config.cjs",
    "test:browser": "playwright test --config tests/browser/playwright.config.ts",
    "test:ci": "npm test && npm run test:browser",
    "test:webgpu": "node -e \"process.env.LUMINA_BROWSER_SMOKE='1'; process.env.LUMINA_WEBGPU_SMOKE='1'; const cp = require('node:child_process'); const r = cp.spawnSync('npx', ['playwright', 'test', '--config', 'tests/browser/playwright.config.ts', 'tests/browser/smoke/webgpu-compute.spec.ts', 'tests/browser/smoke/webgpu-render.spec.ts'], { stdio: 'inherit', shell: true, env: process.env }); process.exit(r.status ?? 1);\"",
    "test:perf": "jest --config jest.config.cjs tests/wasm-perf-validation.test.ts",
    "test:perf:update": "node -e \"process.env.UPDATE_BASELINE='1'; const cp = require('node:child_process'); const r = cp.spawnSync('npx', ['jest', '--config', 'jest.config.cjs', 'tests/wasm-perf-validation.test.ts'], { stdio: 'inherit', shell: true, env: process.env }); process.exit(r.status ?? 1);\"",
    "test:watch": "jest --watch",
    "doctor:webgpu": "node scripts/doctor-webgpu.mjs",
    "init": "tsx src/bin/cli.ts --init",
    "repl:smoke": "node scripts/repl-smoke.cjs",
    "bench:compile": "tsx scripts/benchmark/compile-bench.ts",
    "bench:incremental": "tsx scripts/benchmark/incremental-bench.ts",
    "bench:lsp": "tsx scripts/benchmark/lsp-bench.ts",
    "bench:memory": "node --expose-gc --import tsx scripts/benchmark/memory-bench.ts",
    "bench:runtime": "tsx scripts/benchmark/runtime-bench.ts",
    "bench:wasm-vs-js": "tsx scripts/benchmark/wasm-vs-js-bench.ts",
    "bench:wasm-memory": "node --expose-gc --import tsx scripts/benchmark/wasm-memory-bench.ts",
    "bench:wasm-perf": "npm run test:perf",
    "bench:update-baseline": "npm run test:perf:update",
    "bench:const-generics": "tsx scripts/benchmark/const-generics-bench.ts",
    "bench": "npm run bench:compile && npm run bench:incremental && npm run bench:lsp && npm run bench:runtime && npm run bench:memory && npm run bench:wasm-vs-js && npm run bench:wasm-memory",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "lint:all": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:all:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "prettier": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "pack:check": "node scripts/check-package.cjs && npm pack --dry-run",
    "demo:dev": "npm --prefix demo run dev",
    "demo:build": "npm --prefix demo run build"
  },
  "keywords": [
    "lumina",
    "language",
    "compiler",
    "async",
    "functional",
    "typescript"
  ],
  "author": "nyigoro",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.54.2",
    "@stylistic/eslint-plugin": "^5.8.0",
    "@types/jest": "^30.0.0",
    "@types/moo": "^0.5.10",
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-compact": "^9.0.1",
    "jest": "^30.2.0",
    "lumina-language-client": "file:./packages/lumina-language-client",
    "npm": "^11.9.0",
    "peggy": "^5.0.6",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@swc/core": "^1.15.11",
    "chokidar": "^5.0.0",
    "colorette": "^2.0.20",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "moo": "^0.5.2",
    "source-map": "^0.7.4",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-uri": "^3.1.0"
  },
  "engines": {
    "node": ">=22.17.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyigoro/lumina-lang.git"
  },
  "bugs": {
    "url": "https://github.com/nyigoro/lumina-lang/issues"
  },
  "homepage": "https://github.com/nyigoro/lumina-lang#readme"
}

